ded {len(test_data)} test samples\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"SgSmjRp6cFqD","executionInfo":{"status":"ok","timestamp":1769227961430,"user_tz":-345,"elapsed":21,"user":{"displayName":"Sahil Duwal","userId":"12626940666017853090"}},"outputId":"ac20a000-6b4a-47bd-db50-0f17ffa88a02"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Loaded 1450 test samples\n"]}]},{"cell_type":"code","source":["import json\n","import torch\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","from transformers import AutoTokenizer, AutoModelForTokenClassification\n","from sklearn.metrics import classification_report, precision_score, recall_score, f1_score, confusion_matrix\n","import numpy as np\n","from google.colab import files\n","import pandas as pd\n","\n","# Function to evaluate hate speech detection\n","def evaluate_hate_speech(model, tokenizer, test_data):\n","    \"\"\"Evaluate hate speech detection model\"\"\"\n","    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n","    model.to(device)\n","    model.eval()\n","\n","    all_predictions = []\n","    all_labels = []\n","\n","    for item in test_data:\n","        # Extract text and labels based on JSON structure\n","        if 'text' in item:\n","            text = item['text']\n","        elif 'sentence' in item:\n","            text = item['sentence']\n","        elif 'tokens' in item:\n","            text = ' '.join(item['tokens'])\n","        elif 'Comment' in item: # Assuming 'Comment' is the text field if no other is present\n","            text = item['Comment']\n","        else:\n","            continue\n","\n","        # Extract true label\n","        if 'label' in item:\n","            true_label = item['label']\n","        elif 'labels' in item:\n","            true_label = item['labels']\n","        elif 'ner_tags' in item:\n","            # For NER format, check if any tag indicates offensive content\n","            true_label = 1 if any(tag != 'O' for tag in item['ner_tags']) else 0\n","        elif 'Label_Binary' in item: # Added to handle 'Label_Binary'\n","            true_label = 1 if item['Label_Binary'].upper() == 'OFF' else 0 # Convert 'OFF' to 1, 'NOT' to 0\n","        else:\n","            continue\n","\n","        # Tokenize and predict\n","        inputs = tokenizer(text, return_tensors=\"pt\", truncation=True,\n","                          padding=True, max_length=512)\n","        inputs = {k: v.to(device) for k, v in inputs.items()}\n","\n","        with torch.no_grad():\n","            outputs = model(**inputs)\n","\n","        # Get predictions - aggregate token-level predictions\n","        predictions = torch.argmax(outputs.logits, dim=-1)[0]\n","\n","        # Check if any token is predicted as offensive (non-O tag)\n","        pred_labels = [model.config.id2label.get(p.item(), 'O') for p in predictions]\n","        pred_label = 1 if any(label != 'O' for label in pred_labels) else 0\n","\n","        all_predictions.append(pred_label)\n","        all_labels.append(int(true_label))\n","\n","    return all_labels, all_predictions"],"metadata":{"id":"dTS4aBUHcH0T","executionInfo":{"status":"ok","timestamp":1769227964063,"user_tz":-345,"elapsed":32,"user":{"displayName":"Sahil Duwal","userId":"12626940666017853090"}}},"execution_count":7,"outputs":[]},{"cell_type":"code","source":["# Run evaluation\n","print(\"\\nRunning hate speech detection evaluation...\")\n","try:\n","    true_labels, pred_labels = evaluate_hate_speech(model, tokenizer, test_data)\n","except Exception as e:\n","    print(f\"Error in evaluation: {e}\")\n","    print(\"\\nPlease ensure your JSON has one of these formats:\")\n","    print('1. {\"text\": \"...\", \"label\": 0/1}')\n","    print('2. {\"sentence\": \"...\", \"label\": 0/1}')\n","    print('3. {\"tokens\": [...], \"ner_tags\": [...]}')\n","    raise"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ldF