            0.54           0.42           0.64         0.51\n","======================================================================\n"]}]},{"cell_type":"code","source":["# Visualizations\n","fig = plt.figure(figsize=(16, 10))\n","gs = fig.add_gridspec(3, 3, hspace=0.3, wspace=0.3)\n","\n","# 1. Overall Metrics Comparison (Top Left)\n","ax1 = fig.add_subplot(gs[0, 0])\n","metrics_overall = {\n","    'Precision': (precision_non_off + precision_off) / 2,\n","    'Recall': (recall_non_off + recall_off) / 2,\n","    'F1-Score': (f1_non_off + f1_off) / 2\n","}\n","ax1.bar(metrics_overall.keys(), metrics_overall.values(),\n","        color=['#3498db', '#e74c3c', '#2ecc71'])\n","ax1.set_ylim([0, 1])\n","ax1.set_ylabel('Score', fontsize=10)\n","ax1.set_title('Overall Metrics (Macro Avg)', fontsize=11, fontweight='bold')\n","ax1.grid(axis='y', alpha=0.3)\n","for i, (k, v) in enumerate(metrics_overall.items()):\n","    ax1.text(i, v + 0.02, f'{v:.2f}', ha='center', va='bottom', fontweight='bold')\n","\n","# 2. Non-Offensive vs Offensive Metrics (Top Middle)\n","ax2 = fig.add_subplot(gs[0, 1])\n","x = np.arange(3)\n","width = 0.35\n","non_off_vals = [precision_non_off, recall_non_off, f1_non_off]\n","off_vals = [precision_off, recall_off, f1_off]\n","\n","ax2.bar(x - width/2, non_off_vals, width, label='Non-Offensive', color='#3498db')\n","ax2.bar(x + width/2, off_vals, width, label='Offensive', color='#e74c3c')\n","ax2.set_ylabel('Score', fontsize=10)\n","ax2.set_title('Class-wise Performance', fontsize=11, fontweight='bold')\n","ax2.set_xticks(x)\n","ax2.set_xticklabels(['Precision', 'Recall', 'F1-Score'])\n","ax2.legend()\n","ax2.grid(axis='y', alpha=0.3)\n","ax2.set_ylim([0, 1])\n","\n","# 3. Confusion Matrix (Top Right)\n","ax3 = fig.add_subplot(gs[0, 2])\n","cm = confusion_matrix(true_labels, pred_labels)\n","sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',\n","            xticklabels=['Non-Offensive', 'Offensive'],\n","            yticklabels=['Non-Offensive', 'Offensive'],\n","            ax=ax3, cbar_kws={'label': 'Count'})\n","ax3.set_title('Confusion Matrix', fontsize=11, fontweight='bold')\n","ax3.set_ylabel('True Label', fontsize=10)\n","ax3.set_xlabel('Predicted Label', fontsize=10)\n","\n","# 4. Summary Table Visualization (Middle - spans 2 columns)\n","ax4 = fig.add_subplot(gs[1, :2])\n","ax4.axis('tight')\n","ax4.axis('off')\n","\n","table_data = [\n","    ['Models', 'Non-Offensive\\nPre.', 'Non-Offensive\\nRec.', 'Non-Offensive\\nF1',\n","     'Offensive\\nPre.', 'Offensive\\nRec.', 'Offensive\\nF1'],\n","    ['NepBERTA', f'{precision_non_off:.2f}', f'{recall_non_off:.2f}', f'{f1_non_off:.2f}',\n","     f'{precision_off:.2f}', f'{recall_off:.2f}', f'{f1_off:.2f}']\n","]\n","\n","table = ax4.table(cellText=table_data, cellLoc='center', loc='center',\n","                  colWidths=[0.15, 0.14, 0.14, 0.14, 0.14, 0.14, 0.14])\n","table.auto_set_font_size(False)\n","table.set_fontsize(10)\n","table.scale(1, 2.5)\n","\n","# Style header row\n","for i in range(7):\n","    table[(0, i)].set_facecolor('#34495e')\n","    table[(0, i)].set_text_props(weight='bold', color='white')\n","\n","# Style data row\n","for i in range(7):\n","    table[(1, i)].set_facecolor('#ecf0f1')\n","\n","ax4.set_title('Performance Summary Table', fontsize=12, fontweight='bold', pad=20)\n","\n","# 5. Precision Comparison (Middle Right)\n","ax5 = fig.add_subplot(gs[1, 2])\n","ax5.barh(['Non-Offensive', 'Offensive'], [precision_non_off, precision_off],\n","         color=['#3498db', '#e74c3c'])\n","ax5.set_xlabel('Precision', fontsize=10)\n","ax5.set_title('Precision by Class', fontsize=11, fontweight='bold')\n","ax5.set_xlim([0, 1])\n","ax5.grid(axis='x', alpha=0.3)\n","for i, v in enumerate([precision_non_off, precision_off]):\n","    ax5.text(v + 0.02, i, f'{v:.2f}', va='center', fontweight='bold')\n","\n","# 6. Recall Comparison (Bottom Left)\n","ax6 = fig.add_subplot(gs[2, 0])\n","ax6.barh(['Non-Offensive', 'Offensive'], [recall_non_off, recall_off],\n","         color=['#3498db', '#e74c3c'])\n","ax6.set_xlabel('Recall', fontsize=10)\n","ax6.set_title('Recall by Class', fontsize=11, fontweight='bold')\n","ax6.set_xlim([0, 1])\n","ax6.grid(axis='x', alpha=0.3)\n","for i, v in enumerate([recall_non_off, recall_off]):\n","    ax6.text(v + 0.02, i, f'{v:.2f}', va='center', fontweight='bold')\n","\n","# 7. F1-Score Comparison (Bottom Middle)\n","ax7 = fig.add_subplot(gs[2, 1])\n","ax7.barh(['Non-Offensive', 'Offensive'], [f1_non_off, f1_off],\n","         color=['#3498db', '#e74c3c'])\n","ax7.set_xlabel('F1-Score', fontsize=10)\n","ax7.set_title('F1-Score by Class', fontsize=11, fontweight='bold')\n","ax7.set_xlim([0, 1])\n","ax7.grid(axis='x', alpha=0.3)\n","for i, v in enumerate([f1_non_off, f1_off]):\n","    ax7.text(v + 0.02, i, f'{v:.2f}', va='center', fontweight='bold')\n","\n","# 8. Class Distribution (Bottom Right)\n","ax8 = fig.add_subplot(gs[2, 2])\n","class_counts = [true_labels.count(0), true_labels.count(1)]\n","ax8.pie(class_counts, labels=['Non-Offensive', 'Offensive'],\n","        autopct='%1.1f%%', colors=['#3498db', '#e74c3c'],\n","        startangle=90)\n","ax8.set_title('Test Set Class Distribution', fontsize=11, fontweight='bold')\n","\n","plt.suptitle('Hate Speech Detection - NepBERTA Model Evaluation',\n","             fontsize=14, fontweight='bold', y=0.98)\n","\n","plt.savefig('hate_speech_evaluation.png', dpi=300, bbox_inches='tight')\n","plt.show()\n","\n","print(\"\\n\" + \"=\"*70)\n","print(\"Evaluation complete! Graph saved as 'hate_speech_evaluation.png'\")\n","print(\"=\"*70)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":619},"id":"20Z37E5pcR3T","executionInfo":{"status":"ok","timestamp":1769227999945,"user_tz":-345,"elapsed":3412,"user":{"displayName":"Sahil Duwal","userId":"12626940666017853090"}},"outputId":"a862d812-2567-49d5-bb32-b5f2b5ff2dd7"},"execution_count":11,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x1000 w